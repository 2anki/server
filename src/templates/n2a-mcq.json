  "styling": "html, body {\n  padding: 0;\n  margin: 0;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml {\n  height: 100%;\n}\n\n.card {\n  text-align: center;\n  margin: 0;\n  padding: 1px 1px 1vh 1px;\n  display: flex;\n  flex-direction: column;\n  font-family: Menlo, Baskerville, sans-serif;\n  font-size: clamp(18px, 3vmin, 25px);\n  overflow: auto;\n}\n\n.card-content {\n  flex: 1;\n  padding: 0px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  align-items: center;\n  gap: 2vh;\n}\n\n.stem {\n  font-size: 16px;\n  font-weight: 400;\n  line-height: 1.6;\n  margin: 0;\n  padding: 2vh 1vw;\n  word-break: break-word;\n}\n\n.question {\n  font-size: clamp(20px, 4vmin, 30px);\n  line-height: 1.4;\n  margin: 0;\n  padding: 2vh 1vw;\n  word-break: break-word;\n}\n\n#choices {\n  max-height: 75vh;\n  overflow-y: auto;\n  font-size: clamp(16px, 3.5vmin, 30px);\n  width: 100%;\n  padding: 0;\n  margin: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n#choices li {\n  margin: 1vh 0;\n  padding: 2vh 4vw;\n  border-radius: 6px;\n  border: none;\n  outline: none;\n  box-shadow: none;\n  background: rgba(0, 0, 0, 0.06);\n  transition: background 0.15s ease, transform 0.05s ease;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  min-width: 69%;\n}\n\n#choices li:hover {\n  background: rgba(0, 0, 0, 0.10);\n}\n\n#choices li:active {\n  transform: scale(0.99);\n  background: rgba(0, 0, 0, 0.10);\n}\n\n#choices li.tap {\n  background: rgba(0, 0, 0, 0.16) !important;\n}\n\n#choices.back li.success {\n  background: #ECFDF5;\n  border-left: 1.5px solid #10B981;\n  color: inherit;\n}\n\n#choices.back li.success input[type=\"checkbox\"] {\n  accent-color: #10B981;\n}\n\n#choices.back li.error {\n  background: #FEF2F2;\n  border-left: 1.5px solid #EF4444;\n  color: inherit;\n}\n\n#choices.back li.missed {\n  background: #FFFBEB;\n  border-left: 1.5px solid #F59E0B;\n  opacity: 1;\n}\n\n#choices.back li input[type=\"checkbox\"] {\n  display: none;\n}\n\n#choices.back li::before {\n  content: \"\";\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 34px;\n  height: 34px;\n  margin-right: 4vw;\n  margin-left: 1vw;\n  flex-shrink: 0;\n  font-weight: 700;\n  font-size: 22px;\n  line-height: 1;\n  border: 2px solid rgba(0, 0, 0, 0.2);\n  border-radius: 50%;\n  background: transparent;\n  color: transparent;\n}\n\n#choices.back li.success::before {\n  content: \"\\2713\";\n  color: #10B981;\n  border-color: #10B981;\n  background: #ECFDF5;\n}\n\n#choices.back li.error::before {\n  content: \"\\2715\";\n  color: #EF4444;\n  border: none;\n  background: transparent;\n  font-size: 28px;\n}\n\n#choices.back li.missed::before {\n  content: \"\";\n  border-style: dashed;\n  border-color: #F59E0B;\n  background: transparent;\n}\n\n.check-container {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n}\n\n#check {\n  padding: 2px 10px;\n}\n\n#check.success {\n  color: #10B981;\n  font-weight: bold;\n}\n\n#check.error {\n  color: #EF4444;\n  font-weight: bold;\n}\n\n.big-button {\n  display: block;\n  width: 100%;\n  margin: 1.5vh 0;\n  padding: 2vh 6vw;\n  border: none;\n  outline: none;\n  box-shadow: none;\n  border-radius: 14px;\n  background: rgba(0, 0, 0, 0.06);\n  font-size: clamp(18px, 3.5vmin, 22px);\n  color: inherit;\n  cursor: pointer;\n  user-select: none;\n  text-align: center;\n  transition: background 0.15s ease, transform 0.05s ease;\n}\n\n.big-button:hover {\n  background: rgba(0, 0, 0, 0.10);\n}\n\n.big-button:active {\n  transform: scale(0.99);\n  background: rgba(0, 0, 0, 0.10);\n}\n\n.button-container {\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  background: transparent;\n  padding: 1.5vh 2vw;\n  display: flex;\n  flex-direction: column;\n  gap: 1vh;\n  z-index: 100;\n}\n\n@media (min-width: 768px) {\n  .button-container {\n    flex-direction: row;\n    justify-content: center;\n    padding: 2vh 5vw;\n  }\n  .big-button {\n    width: auto;\n    min-width: 30vw;\n    padding: 4vh 15vw;\n  }\n}\n\n#choices li input {\n  margin-right: 4vw;\n  margin-left: 1vw;\n  min-width: 34px;\n  min-height: 34px;\n  flex-shrink: 0;\n}\n\n#choices li span {\n  flex-grow: 1;\n  line-height: 1.4;\n}\n\n.hint {\n  margin-top: 20px;\n  font-size: 70%;\n  color: #aaa;\n}\n\n.back#choices input {\n  pointer-events: none;\n  max-height: 85vh;\n  overflow-y: auto;\n  font-size: clamp(16px, 3vmin, 20px);\n}\n\np#answer {\n  border-top: 2px solid black;\n}\n\nul {\n  display: inline-block;\n  margin-top: 0;\n}\n\nli {\n  text-align: left;\n  list-style: none;\n  margin: 10px;\n}\n\nli input {\n  margin-left: -20px;\n}\n\n.explanation-block {\n  display: block;\n  max-width: 600px;\n  text-align: left;\n  border-top: 1px solid #ccc;\n  padding-top: 10px;\n  margin: 0 auto 10px;\n}\n\n.explanation-heading {\n  font-weight: 600;\n  font-size: 0.875rem;\n  text-transform: uppercase;\n  letter-spacing: 0.05em;\n  margin-bottom: 0.5rem;\n  color: inherit;\n  opacity: 0.7;\n}\n\n.explanation-body {\n  font-size: 14px;\n  border-left: 3px solid currentColor;\n  padding-left: 1rem;\n  opacity: 0.85;\n}\n\n#choices li.disabled {\n  opacity: 0.22;\n  pointer-events: none;\n  cursor: not-allowed;\n}\n\n#choices b,\n#choices i,\n#choices u {\n  color: inherit !important;\n}\n\n#choices u {\n  text-decoration: underline;\n  font-weight: normal;\n}\n\n#choices i {\n  font-style: italic;\n  font-weight: normal;\n}\n\nimg { display: block; max-width: 100%; margin: 10px auto; }\n"
