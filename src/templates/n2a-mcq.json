  "styling": "/* --- ADD THIS ENTIRE BLOCK AT THE TOP --- */\nhtml, body {\n  padding: 0;\n  margin: 0;\n}\n\n\n.error {\n  color: #F04A32;\n  font-weight: bold;\n}\n\n.success {\n  color: #8AC05E;\n  font-weight: bold;\n}\n\n.missed {\n  color: #F4E45F;\n  font-weight: bold;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml {\n  height: 100%;\n}\n\n.card {\n  text-align: center;\n  margin: 0;\n  padding: 1px 1px 1vh 1px; /* Top, Right, Bottom, Left. Adjust 150px as needed. */\n/*  height: 95vh;  Full viewport height */\n  display: flex;\n  flex-direction: column;\n  font-family: Menlo, Baskerville, sans-serif;    \n  font-size: clamp(18px, 3vmin, 25px); /* Responsive base font */\n  /*background: ;*/\n  overflow: auto; /* Scroll if content overflows */\n}\n\n\n.card-content {\n  flex: 1; /* Takes remaining space */\n  padding: 0px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center; /* Centers content vertically */\n  \n  /* --- ADD THIS LINE --- */\n  align-items: center; /* This will center all direct children, including #choices */\n  \n  gap: 2vh; /* Spacing between elements */\n}\n\n\n\n.question {\n  font-size: clamp(20px, 4vmin, 30px); \n  line-height: 1.4;\n  margin: 0;\n  padding: 2vh 1vw;\n  word-break: break-word; /* Prevents overflow */\n}\n\n\n\n/* Choices (flexible but constrained) */\n#choices {\n  max-height: 75vh;\n  overflow-y: auto;\n  font-size: clamp(16px, 3.5vmin, 30px);\n\n  /* --- FIXES APPLIED HERE --- */\n  width: 100%; /* Forces the container to span the full width */\n  padding: 0;   /* Removes default browser indentation */\n  margin: 0;    /* Good practice to reset margin */\n  \n  display: flex;\n  flex-direction: column;\n  align-items: center; /* This will now center the LI elements correctly */\n}\n\n/* Multiple choice items (responsive) */\n#choices li {\n  margin: 1vh 0;\n  padding: 2vh 4vw;\n  border-radius: 12px;\n  border: none;\n  outline: none;\n  box-shadow: none;\n  background: rgba(0, 0, 0, 0.06);\n  transition: background 0.15s ease, transform 0.05s ease;\n  cursor: pointer;\n  display: flex; \n  align-items: center;\n  \n  /* Optional: Add a width to prevent items from being too narrow on big screens */\n  min-width: 69%;  /* Adjust as needed */\n  \n/*  max-width: 600px;  A pixel-based max is good for consistency */\n}\n\n#choices li:hover {\n  background: rgba(0, 0, 0, 0.10);\n}\n\n#choices li:active {\n  transform: scale(0.99);\n  background: rgba(0, 0, 0, 0.10);\n}\n\n#choices li.tap {\n  background: rgba(0, 0, 0, 0.16) !important;\n}\n\n.big-button {\n  display: block;\n  width: 100%;\n  margin: 1.5vh 0;\n  padding: 2vh 6vw;\n\n  border: none;\n  outline: none;\n  box-shadow: none;\n\n  border-radius: 14px;\n  background: rgba(0, 0, 0, 0.06);\n\n  font-size: clamp(18px, 3.5vmin, 22px);\n  color: inherit;\n\n  cursor: pointer;\n  user-select: none;\n  text-align: center;\n\n  transition: background 0.15s ease, transform 0.05s ease;\n}\n\n.big-button:hover {\n  background: rgba(0, 0, 0, 0.10);\n}\n\n.big-button:active {\n  transform: scale(0.99);\n  background: rgba(0, 0, 0, 0.10);\n}\n\n.big-button.tap {\n  background: rgba(0, 0, 0, 0.16) !important;\n}\n\n#choices.back li.success {\n  color: #8AC05E !important;\n  font-weight: bold;\n}\n\n#choices.back li.error {\n  color: #F04A32 !important;\n  font-weight: bold;\n}\n\n#choices.back li.missed {\n  opacity: 0.75;\n}\n\n\n\n\n/* Ensure the input (radio button) and text are well-aligned */\n#choices li input {\n  margin-right: 4vw; /* Added margin to separate the radio button from the text */\n  margin-left: 1vw;\n  min-width: 34px; /* Ensure the radio button itself has a minimum clickable size */\n  min-height: 34px;\n\tflex-shrink: 0; /* Prevents the checkbox from shrinking */\n  /* You might need to adjust the appearance of default radio buttons */\n  /* For custom radio buttons, you'd use appearance: none and custom styling */\n}\n\n/* If you want the text itself to be more prominent */\n#choices li span { /* Assuming your choice text is wrapped in a span or similar */\n  flex-grow: 1; /* Allows the text to take up remaining space */\n  line-height: 1.4; /* Improve readability for larger text */\n}\n\n.hint {\n  margin-top: 20px;\n  font-size: 70%;\n  color: #aaa;\n}\n\n.extra {\n  font-size: clamp(14px, 2.5vmin, 18px);\n  margin: 1vh 0;\n}\n\n.back#choices input {\n  pointer-events: none;\n  max-height: 85vh; /* Prevents taking too much space */\n  overflow-y: auto; /* Scroll if too many choices */\n  font-size: clamp(16px, 3vmin, 20px);\n}\n\np#answer {\n  border-top: 2px solid black;\n}\n\nul {\n  display: inline-block;\n  margin-top: 0;\n}\n\nli {\n  text-align: left;\n  list-style: none;\n  margin: 10px;\n}\n\nli input {\n  margin-left: -20px;\n}\n\n#explanation {\n  display: block;\n  max-width: 600px;\n  font-size: 14px;\n  text-align: left;\n  border-top: 1px solid #ccc;\n  padding-top: 10px;\n  margin: 0 auto;\n  margin-bottom: 10px;\n}\n\n.check-container {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n}\n\n#check {\n  padding: 2px 10px;\n}\n\n/* New styles for the fixed buttons */\n.button-container {\n  position: fixed;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  background: transparent;\n  padding: 1.5vh 2vw; /* Viewport-based padding */\n/*  box-shadow: \n    0 4px 8px rgba(0, 0, 0, 0.3),  Base shadow */\n/*    0 6px 12px rgba(0, 0, 0, 0.2);  Secondary shadow for depth */\n  display: flex;\n  flex-direction: column;\n  gap: 1vh; /* Viewport gap */\n  z-index: 100;\n}\n\n.big-button {\n  padding: 4vh 15vw; /* Scales with viewport */\n  font-size: clamp(16px, 2.5vh, 24px); /* Responsive font scaling */\n  width: 100%;\n  border: none;\n  background: rgba(0, 0, 0, 0.06);\n/*  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3), 0 6px 12px rgba(0, 0, 0, 0.2);*/\n  color: black; \n  border-radius: 5px;\n  cursor: pointer;\n/*  transition: background-color 0.3s;*/\n}\n\n.hint-text {\n  display: block;\n  margin-top: 10px;\n  font-size: clamp(14px, 1.8vh, 18px); /* Responsive hint text */\n  color: #555;\n  text-align: center;\n}\n\n@media (min-width: 768px) {\n  .button-container {\n    flex-direction: row;\n    justify-content: center;\n\t\tpadding: 2vh 5vw; /* Wider padding on desktop */\n  }\n  .big-button {\n    width: auto;\n    min-width: 30vw; /* Relative to viewport width */\n    padding: 4vh 15vw;\n  }\n}\n\n/* COLOR ACCENTS FOR BOLD-ITALICS-UNDERLINE */\nb { color: #C695C6 !important; } /* BOLD STYLE */\nu { text-decoration: none; font-weight: bold; color: #6fbbbb;} /* UNDERLINE STYLE */\ni  { font-style: normal; font-weight: bold; color: IndianRed; } /* ITALICS STYLE */\na { color: LightGray !important; text-decoration: none; font-size: 18px; font-style: normal; } /* LINK STYLE */\n\n/* FIX: Reset b, i, u styles within choice boxes */\n#choices b,\n#choices i,\n#choices u {\n  color: inherit !important; /* Inherit color from the parent (the choice text) */\n}\n\n#choices u {\n  text-decoration: underline; /* Restore the default underline */\n  font-weight: normal; /* Restore the default font weight */\n}\n\n#choices i {\n  font-style: italic; /* Restore the default italic style */\n  font-weight: normal; /* Restore the default font weight */\n}\n\n\n/* IMAGE STYLE */\nimg { display: block; max-width: 100%; margin: 10px auto;}\n\n/* --- ADDED STYLES FOR NEW INTERACTIVE FEATURES --- */\n\n/* Style for a selected answer choice */\n#choices li.selected {\n  background: rgba(0, 0, 0, 0.12);\n}\n\n/* Style for disabled (unselectable) choices when the max count is reached */\n#choices li.disabled {\n  opacity: 0.22;\n  pointer-events: none; /* Disables all click events */\n  cursor: not-allowed;\n}\n\n/* Wrapper for the new answer counter */\n.counter-container {\n  text-align: center;\n  margin-top: 10px;\n}\n\n/* The counter text element itself */\n#answer-counter {\n  font-size: clamp(10px, 2.5vmin, 16px);\n  font-weight: bold;\n  color: #333;\n  margin-top: 10px;\n  padding: 1px 1px;\n  border-radius: 8px;\n  background-color: transparent;\n  display: inline-block;\n  transition: all 0.3s ease;\n}\n\n/* The 'completion glow' effect on the counter */\n#answer-counter.glow {\n  animation: glow-effect .69s ease-out;\n}\n\n@keyframes glow-effect {\n  0%, 100% {\n    transform: scale(1);\n    box-shadow: none;\n    color: #333;\n  }\n  50% {\n    transform: scale(1.1);\n    color: #4CAF50; /* A success green for the text color */\n    text-shadow: 0 0 8px rgba(76, 175, 80, 0.7); /* Green text glow */\n    box-shadow: 0 0 15px rgba(76, 175, 80, 0.5); /* Green box glow */\n  }\n}\n\n\n/* --- Style for Social Media Links --- */\n/* The @import rule was removed from here and placed in the template HTML */\n\n.social-links {\n  text-align: center; /* Center the icons */\n  margin-top: 25px;   /* Add some space above the icons */\n  padding-top: 15px;  /* Add a little more space */\n  border-top: 1px solid #ddd; /* Add a faint line to separate them */\n}\n\n.social-links a {\n  font-size: 28px;      /* Make icons larger */\n  color: #888;         /* Set a neutral gray color */\n  text-decoration: none;/* Remove the default link underline */\n  margin: 0 12px;       /* Add space between each icon */\n  transition: color 0.2s ease-in-out; /* Smooth color change on hover */\n}\n\n/* Change color when you hover over an icon */\n.social-links a:hover {\n  color: #333; /* Darken the icon on hover */\n}\n"
}